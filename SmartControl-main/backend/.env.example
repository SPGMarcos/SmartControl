# Supabase service role credentials
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-chave-de-servico

# Broker MQTT em nuvem (EMQX Cloud, HiveMQ Cloud, HiveMQ Free, etc.)
# Backend Node pode usar mqtts://host:8883 ou wss://host:porta/mqtt.
MQTT_URL=mqtts://broker.example.com:8883
MQTT_USERNAME=seu-usuario-mqtt
MQTT_PASSWORD=sua-senha-mqtt
MQTT_CLIENT_ID=smartcontrol-backend
MQTT_STATUS_TOPICS=smartcontrol/+/+/+/status,smartcontrol/+/+/+/telemetry,smartcontrol/+/+/+/heartbeat,smartcontrol/+/+/+/ack,smartcontrol/+/+/+/availability,smartcontrol/+/+/+/config,smartcontrol/pairing/+/announce
MQTT_REJECT_UNAUTHORIZED=true
MQTT_REQUIRE_DEVICE_TOKEN=false

# Em producao, use seu dominio GitHub Pages e REQUIRE_AUTH=true.
CORS_ORIGIN=http://localhost:5173,https://seu-usuario.github.io
REQUIRE_AUTH=true

# Porta do servidor de integracao backend
PORT=4000
