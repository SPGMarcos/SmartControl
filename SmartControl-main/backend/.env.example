# Supabase service role credentials
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-chave-de-servico

# Broker MQTT em nuvem (EMQX Cloud, HiveMQ Cloud, etc.)
MQTT_URL=wss://broker.example.com:8084/mqtt
MQTT_USERNAME=seu-usuario-mqtt
MQTT_PASSWORD=sua-senha-mqtt
MQTT_CLIENT_ID=smartcontrol-backend

# Porta do servidor de integração backend
PORT=4000
